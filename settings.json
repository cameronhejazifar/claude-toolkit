{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(cd api && ./vendor/bin/sail *)",
      "Bash(cd web && docker compose *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch --show-current)",
      "Bash(git branch --list *)",
      "Bash(git checkout -- *)",
      "Bash(git worktree *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "mcp__context7__*",
      "mcp__boost__*"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git branch -m *)",
      "Bash(git checkout -b *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(rm -rf *)",
      "Bash(sail artisan migrate:fresh *)",
      "Bash(sail artisan migrate:reset *)",
      "Bash(sail artisan db:wipe *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-pint.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-eslint.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}